# Copy this file to ".env" for local dev, or set these in your Vercel project
# settings (Project → Settings → Environment Variables) for production.

# Required: your Anthropic API key. Get one at https://console.anthropic.com
# (Settings → API Keys). Keep it SECRET — never commit it or put it in index.html.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: which Claude model powers the demo. Haiku is fast + cheap and is the
# default. For richer briefs you can switch to claude-sonnet-4-6.
OTTO_MODEL=claude-haiku-4-5-20251001
